{
    "name": "ca-experiment",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Web port of an old Processing cellular-automaton sketch — TypeScript + thi.ng/umbrella, declarative shell, typed-array core.",
    "scripts": {
        "dev": "vite",
        "build": "tsc --noEmit && vite build",
        "build:single": "tsc --noEmit && vite build --mode singlefile",
        "preview": "vite preview",
        "test": "esbuild test/verify.ts --bundle --platform=node --format=esm --outfile=node_modules/.cache/verify.mjs && node node_modules/.cache/verify.mjs"
    },
    "dependencies": {
        "@thi.ng/atom": "^5.3.67",
        "@thi.ng/pixel": "^4.3.4",
        "@thi.ng/rdom": "^1.7.89",
        "@thi.ng/rstream": "^9.5.10",
        "@thi.ng/rstream-gestures": "^4.1.48",
        "@thi.ng/transducers": "^9.6.40"
    },
    "devDependencies": {
        "esbuild": "^0.24.0",
        "typescript": "^5.6.3",
        "vite": "^5.4.10",
        "vite-plugin-singlefile": "^2.0.3"
    }
}
